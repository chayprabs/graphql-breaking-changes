{
  "name": "graphql-breaking-changes",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Diff two GraphQL schemas online and find breaking and dangerous changes - operation coverage and federation composition checks.",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @graphql-guard/web dev",
    "lint": "eslint . && pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @graphql-guard/web test:e2e",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "graphql": "16.14.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "graphql": "16.14.0",
    "typescript-eslint": "^8.18.2"
  }
}
