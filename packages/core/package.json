{
  "name": "@graphql-guard/core",
  "version": "1.0.0",
  "description": "GraphQL schema diff, operation coverage, federation composition, and lint for browser and Node",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fixtures/samples": {
      "types": "./dist/fixtures/samples.d.ts",
      "import": "./dist/fixtures/samples.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'lint via root eslint'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@theguild/federation-composition": "^0.20.2",
    "graphql": "^16.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
